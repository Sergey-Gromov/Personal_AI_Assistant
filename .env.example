# Copy this file to .env and fill in your own values.
# Never commit .env or real API keys to git.

# Required secrets
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_or_proxyapi_key_here

# Telegram network settings (optional)
TELEGRAM_PROXY_URL=
TELEGRAM_REQUEST_TIMEOUT=90

# API routing
# true: use ProxyAPI endpoint; false: use official OpenAI endpoint
USE_PROXYAPI=true

# Bot defaults
BOT_MODE=rag
DEFAULT_VOICE=alloy

# Storage
DB_PATH=data/embeddings.db

# Logging
LOG_LEVEL=INFO
