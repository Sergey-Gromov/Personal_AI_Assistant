# Copy this file to .env and fill in your own values.
# Never commit .env or real API keys to git.

# Required secrets
# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# OpenAI API key from your OpenAI account.
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI-compatible API base URL.
OPENAI_API_BASE=https://api.openai.com/v1

# Proxy settings for local sing-box on 127.0.0.1:1080.
# SOCKS_PROXY_URL is used by the app; HTTP(S)_PROXY are standard env vars for libraries.
SOCKS_PROXY_URL=socks5://127.0.0.1:1080
HTTP_PROXY=socks5://127.0.0.1:1080
HTTPS_PROXY=socks5://127.0.0.1:1080

# Telegram network settings
TELEGRAM_REQUEST_TIMEOUT=90

# Bot defaults
BOT_MODE=rag
DEFAULT_VOICE=alloy

# Storage
DB_PATH=data/embeddings.db

# Logging
LOG_LEVEL=INFO
